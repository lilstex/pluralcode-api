generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// STATUS

enum Role {
  SUPER_ADMIN
  CONTENT_ADMIN
  EVENT_ADMIN
  RESOURCE_ADMIN
  NGO_MEMBER
  EXPERT
  GUEST
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum FormStatus {
  IN_PROGRESS
  SUBMITTED
  COMPLETED
}

enum ResourceType {
  DOCUMENT
  VIDEO
  ARTICLE
}

enum MentorRequestStatus {
  PENDING
  APPROVED
  DECLINED
  COMPLETED
}

enum ODABlockStatus {
  IN_PROGRESS
  SUBMITTED
}

enum NewsPostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum SpotlightMode {
  AUTO
  MANUAL
}

// MODELS

model User {
  id                     String         @id @default(uuid())
  email                  String         @unique
  passwordHash           String
  fullName               String
  role                   Role           @default(GUEST)
  status                 ApprovalStatus @default(PENDING)
  isEmailVerified        Boolean        @default(false)
  otp                    String?
  otpExpiresAt           DateTime?
  resetPasswordToken     String?        @unique
  resetPasswordExpiresAt DateTime?
  avatarUrl              String?
  phoneNumber            String?
  pointsCount            Int            @default(0)

  organization            Organization?
  organizationMemberships OrganizationMember[]
  expertProfile           ExpertProfile?
  adminPermission         AdminPermission?
  badges                  Badge[]
  events                  EventRegistration[]
  downloads               DownloadLog[]
  actionsPerformed        AuditLog[]
  mentorRequests          MentorRequest[]      @relation("MentorRequests")
  mentorAssignments       MentorRequest[]      @relation("MentorAssignments")

  communitiesCreated   Community[]           @relation("CommunityCreator")
  communityMemberships CommunityMembership[] @relation("CommunityMemberships")
  topicsAuthored       CommunityTopic[]      @relation("TopicAuthor")
  commentsAuthored     CommunityComment[]    @relation("CommentAuthor")
  communityLikes       CommunityLike[]       @relation("CommunityLikes")
  communityReports     CommunityReport[]     @relation("CommunityReports")
  communityMentions    CommunityMention[]    @relation("CommunityMentions")

  resourceViews       ResourceView[]       @relation("ResourceViews")
  resourceCompletions ResourceCompletion[] @relation("ResourceCompletions")

  newsPosts NewsPost[] @relation("NewsAuthor")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
  @@index([status])
  @@index([resetPasswordToken])
}

model ExpertProfile {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  title                       String?
  yearsOfExperience           Int?
  about                       String? @db.Text
  employer                    String?
  otherExperience             String? @db.Text
  mentoringPhilosophy         String? @db.Text
  previousMentoringExperience String? @db.Text
  capacityOfMentees           String?

  education               Json     @default("[]")
  areasOfExpertise        String[]
  servicesOffered         String[]
  referees                Json     @default("[]")
  preferredContactMethods String[]
  socials                 Json     @default("[]")
  otherLinks              Json     @default("[]")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Organization {
  id          String  @id @default(uuid())
  name        String
  acronym     String?
  cacNumber   String  @unique
  phoneNumber String
  publicEmail String?
  state       String
  lga         String
  address     String?
  description String? @db.Text
  logoUrl     String?

  mission String?  @db.Text
  vision  String?  @db.Text
  sectors String[]

  numberOfStaff      Int?
  numberOfVolunteers Int?
  annualBudget       String?

  socials    Json @default("[]")
  otherLinks Json @default("[]")

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  members OrganizationMember[]

  activities     OrganizationActivity[]
  donors         OrganizationDonor[]
  assessments    OrganizationAssessment[]
  odaAssessments ODAAssessment[]
  devPlanPriorityAreas DevPlanPriorityArea[]

  spotlightEntries  SpotlightEntry[]
  spotlightHistory  SpotlightHistory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([state])
}

model OrganizationMember {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  orgRole     String   @default("member")
  // Membership status — active | suspended | removed
  status      String   @default("active")
  invitedById String?
  joinedAt    DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // A user can only have one membership record per organization
  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([userId])
}

model OrganizationActivity {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  sector   String
  who      String
  where    String
  when     Int
  activity String @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
}

model OrganizationDonor {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  donor    String
  amount   String
  duration String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
}

model OrganizationAssessment {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  assessmentBody String
  month          Int
  year           Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
}

model AdminPermission {
  id          String   @id @default(uuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Stores an array of permission strings e.g. ["event:read", "event:write"]
  permissions String[]
  updatedAt   DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String // e.g., "USER_DELETED", "RESOURCE_UPLOADED"
  entity    String // e.g., "User", "Resource"
  entityId  String
  details   Json?
  adminId   String
  admin     User     @relation(fields: [adminId], references: [id])
  createdAt DateTime @default(now())
}

model ODAPillar {
  id    String @id @default(uuid())
  name  String @unique
  order Int

  buildingBlocks ODABuildingBlock[]
  devPlanPriorityAreas DevPlanPriorityArea[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ODABuildingBlock {
  id       String @id @default(uuid())
  name     String @unique
  order    Int
  maxScore Int    @default(100)

  pillarId String
  pillar   ODAPillar @relation(fields: [pillarId], references: [id], onDelete: Cascade)

  questions      ODAQuestion[]
  blockResponses ODABlockResponse[]
  devPlanPriorityAreas DevPlanPriorityArea[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([pillarId])
}

model ODAQuestion {
  id    String @id @default(uuid())
  text  String @db.Text
  order Int

  buildingBlockId String
  buildingBlock   ODABuildingBlock @relation(fields: [buildingBlockId], references: [id], onDelete: Cascade)

  devPlanPriorityAreas DevPlanPriorityArea[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([buildingBlockId])
}

model ODAAssessment {
  id           String     @id @default(uuid())
  status       FormStatus @default(IN_PROGRESS)
  overallScore Float?
  aiSummary    String?    @db.Text
  startedAt    DateTime   @default(now())
  completedAt  DateTime?

  orgId        String
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  blockResponses ODABlockResponse[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
  @@index([status])
}

model ODABlockResponse {
  id         String         @id @default(uuid())
  status     ODABlockStatus @default(IN_PROGRESS)
  blockScore Float?

  // answers: [{ questionId, questionText, selectedScale (1-4), evidence }]
  answers Json @default("[]")

  assessmentId String
  assessment   ODAAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  buildingBlockId String
  buildingBlock   ODABuildingBlock @relation(fields: [buildingBlockId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([assessmentId, buildingBlockId])
  @@index([assessmentId])
}

model Badge {
  id             String  @id @default(uuid())
  name           String  @unique
  imageUrl       String
  externalSource Boolean @default(false)

  users     User[]
  resources Resource[]

  createdAt DateTime @default(now())
}

model Category {
  id   String @id @default(uuid())
  name String @unique

  parentId  String?
  parent    Category?  @relation("SubCategories", fields: [parentId], references: [id])
  children  Category[] @relation("SubCategories")
  resources Resource[]
}

model Tag {
  id        String     @id @default(uuid())
  name      String     @unique
  resources Resource[]
}

model Resource {
  id          String       @id @default(uuid())
  title       String
  description String       @db.Text
  contentUrl  String?
  rawText     String?      @db.Text
  type        ResourceType
  author      String?
  language    String?
  region      String?
  sector      String?
  fileSize    Int?
  points      Int          @default(0)

  badgeId String?
  badge   Badge?  @relation(fields: [badgeId], references: [id])

  categoryId String
  category   Category      @relation(fields: [categoryId], references: [id])
  tags       Tag[]
  downloads  DownloadLog[]

  views       ResourceView[]
  completions ResourceCompletion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
  @@index([type])
  @@index([language])
  @@index([sector])
  @@index([region])
  @@index([createdAt])
  @@index([badgeId])
}

model ResourceView {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation("ResourceViews", fields: [userId], references: [id], onDelete: Cascade)
  resourceId String
  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  viewedAt   DateTime @default(now())

  @@unique([userId, resourceId])
  @@index([userId])
  @@index([resourceId])
}

model ResourceCompletion {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation("ResourceCompletions", fields: [userId], references: [id], onDelete: Cascade)
  resourceId  String
  resource    Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  pointsEarned Int     @default(0)
  completedAt DateTime @default(now())

  @@unique([userId, resourceId])
  @@index([userId])
  @@index([resourceId])
}

model DownloadLog {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  resourceId String
  resource   Resource @relation(fields: [resourceId], references: [id])
  timestamp  DateTime @default(now())

  @@index([userId])
  @@index([resourceId])
}

model Event {
  id                 String   @id @default(uuid())
  title              String
  description        String   @db.Text
  startTime          DateTime
  endTime            DateTime
  coverImageUrl      String? // Azure Blob URL
  jitsiRoomId        String   @unique
  externalMeetingUrl String? // Overrides Jitsi if set (Zoom, Teams, etc.)
  capacity           Int? // null = unlimited
  tags               String[] // Thematic tags for discovery
  isPast             Boolean  @default(false)
  isCancelled        Boolean  @default(false)
  cancellationReason String?
  archiveUrl         String? // Azure Media Services recording URL

  registrations EventRegistration[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([startTime])
  @@index([isPast])
  @@index([isCancelled])
}

model EventRegistration {
  id        String   @id @default(uuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, eventId]) // Prevents double registration
}

model MentorRequest {
  id String @id @default(uuid())

  ngoUserId String
  ngoUser   User   @relation("MentorRequests", fields: [ngoUserId], references: [id])

  mentorId String
  mentor   User   @relation("MentorAssignments", fields: [mentorId], references: [id])

  status          MentorRequestStatus @default(PENDING)
  hoursPerWeek    String?
  mentorshipAreas String[]
  commMethods     String[]
  orgChallenges   String?             @db.Text
  background      String?             @db.Text
  acceptedTerms   Boolean             @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ngoUserId])
  @@index([mentorId])
}

model DevPlanPriorityArea {
  id    String @id @default(uuid())

  orgId        String
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  pillarId String
  pillar   ODAPillar @relation(fields: [pillarId], references: [id])

  buildingBlockId String
  buildingBlock   ODABuildingBlock @relation(fields: [buildingBlockId], references: [id])

  indicatorId String
  indicator   ODAQuestion @relation(fields: [indicatorId], references: [id])

  score       Float?
  strength    String? @db.Text
  weakness    String? @db.Text
  opportunity String? @db.Text
  threat      String? @db.Text
  priority    Int     // 1 | 2 | 3 | 4
  act         String? @db.Text

  actionPlan DevPlanActionPlan?
  evaluation DevPlanEvaluation?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
  @@index([pillarId])
  @@index([buildingBlockId])
  @@index([indicatorId])
}

model DevPlanActionPlan {
  id String @id @default(uuid())

  priorityAreaId String              @unique
  priorityArea   DevPlanPriorityArea @relation(fields: [priorityAreaId], references: [id], onDelete: Cascade)

  objective         String?   @db.Text
  kpi               String?   @db.Text
  actionSteps       String?   @db.Text
  responsiblePerson String?
  timeline          DateTime?
  support           String?   @db.Text
  resourcePlan      String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DevPlanEvaluation {
  id String @id @default(uuid())

  priorityAreaId String              @unique
  priorityArea   DevPlanPriorityArea @relation(fields: [priorityAreaId], references: [id], onDelete: Cascade)

  whatWasDone        String? @db.Text
  wereObjectivesMet  String? @db.Text
  whatDidWeLearn     String? @db.Text
  nextSteps          String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// COMMUNITY

model Community {
  id          String  @id @default(uuid())
  name        String  @unique
  description String? @db.Text
  imageUrl    String?
  isActive    Boolean @default(true)

  createdById String
  createdBy   User   @relation("CommunityCreator", fields: [createdById], references: [id])

  memberships CommunityMembership[]
  topics      CommunityTopic[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

model CommunityMembership {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation("CommunityMemberships", fields: [userId], references: [id], onDelete: Cascade)
  communityId String
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  joinedAt    DateTime  @default(now())

  @@unique([userId, communityId])
  @@index([userId])
  @@index([communityId])
}

model CommunityTopic {
  id          String    @id @default(uuid())
  title       String
  body        String    @db.Text
  isBlocked   Boolean   @default(false)
  likeCount   Int       @default(0)

  communityId String
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  authorId String
  author   User   @relation("TopicAuthor", fields: [authorId], references: [id])

  comments CommunityComment[]
  reports  CommunityReport[]
  likes    CommunityLike[]
  mentions CommunityMention[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([communityId])
  @@index([authorId])
  @@index([isBlocked])
}

model CommunityComment {
  id        String @id @default(uuid())
  body      String @db.Text
  likeCount Int    @default(0)

  topicId String
  topic   CommunityTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)

  authorId String
  author   User   @relation("CommentAuthor", fields: [authorId], references: [id])

  // Flat threading — replies point to a top-level comment
  parentId String?
  parent   CommunityComment?  @relation("Replies", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  replies  CommunityComment[] @relation("Replies")

  likes    CommunityLike[]
  mentions CommunityMention[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([topicId])
  @@index([authorId])
  @@index([parentId])
}

model CommunityLike {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation("CommunityLikes", fields: [userId], references: [id], onDelete: Cascade)
  topicId   String?
  topic     CommunityTopic?   @relation(fields: [topicId], references: [id], onDelete: Cascade)
  commentId String?
  comment   CommunityComment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, topicId])
  @@unique([userId, commentId])
  @@index([userId])
}

model CommunityReport {
  id           String @id @default(uuid())
  reason       String? @db.Text
  reportedById String
  reportedBy   User   @relation("CommunityReports", fields: [reportedById], references: [id], onDelete: Cascade)
  topicId      String
  topic        CommunityTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())

  @@unique([topicId, reportedById])
  @@index([topicId])
  @@index([reportedById])
}

model CommunityMention {
  id              String   @id @default(uuid())
  mentionedUserId String
  mentionedUser   User     @relation("CommunityMentions", fields: [mentionedUserId], references: [id], onDelete: Cascade)
  topicId         String?
  topic           CommunityTopic?   @relation(fields: [topicId], references: [id], onDelete: Cascade)
  commentId       String?
  comment         CommunityComment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())

  @@index([mentionedUserId])
}

// NEWS / BLOG

model NewsPost {
  id          String          @id @default(uuid())
  title       String
  slug        String          @unique
  type        String
  body        String          @db.Text
  excerpt     String?         @db.Text
  thumbnailUrl String?
  attachments Json            @default("[]")  // [{ name, url, size }]
  status      NewsPostStatus  @default(DRAFT)
  publishedAt DateTime?
  tags        String[]
  viewCount   Int             @default(0)

  authorId String
  author   User   @relation("NewsAuthor", fields: [authorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([type])
  @@index([authorId])
  @@index([publishedAt])
  @@index([viewCount])
}

// Spotlight

model SpotlightSettings {
  id               String        @id @default("singleton")
  defaultPeriodDays Int          @default(2)
  mode             SpotlightMode @default(AUTO)
  updatedAt        DateTime      @updatedAt
}

model SpotlightEntry {
  id        String       @id @default(uuid())
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  startAt   DateTime
  endAt     DateTime
  isActive  Boolean      @default(false)
  wasAuto   Boolean      @default(false)
  order     Int?
  createdAt DateTime     @default(now())

  @@index([isActive])
  @@index([startAt])
  @@index([endAt])
}

model SpotlightHistory {
  id        String       @id @default(uuid())
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  startAt   DateTime
  endAt     DateTime
  wasAuto   Boolean
  createdAt DateTime     @default(now())

  @@index([orgId])
  @@index([startAt])
}