generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  CONTENT_ADMIN
  EVENT_ADMIN
  RESOURCE_ADMIN
  NGO_MEMBER
  EXPERT
  GUEST
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum FormStatus {
  IN_PROGRESS
  SUBMITTED
  COMPLETED
}

enum ResourceType {
  DOCUMENT
  VIDEO
  ARTICLE
}

model User {
  id                     String         @id @default(uuid())
  email                  String         @unique
  passwordHash           String
  fullName               String
  role                   Role           @default(GUEST)
  status                 ApprovalStatus @default(PENDING)
  isEmailVerified        Boolean        @default(false)
  otp                    String?
  otpExpiresAt           DateTime?
  resetPasswordToken     String?        @unique
  resetPasswordExpiresAt DateTime?
  avatarUrl              String?
  phoneNumber            String?
  pointsCount            Int            @default(0)

  organization            Organization?
  organizationMemberships OrganizationMember[]
  expertProfile           ExpertProfile?
  adminPermission         AdminPermission?
  forumThreads            ForumThread[]
  posts                   Post[]
  badges                  Badge[]
  events                  EventRegistration[]
  downloads               DownloadLog[]
  actionsPerformed        AuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
  @@index([status])
  @@index([resetPasswordToken])
}

model ExpertProfile {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  title                       String?
  yearsOfExperience           Int?
  about                       String? @db.Text
  employer                    String?
  otherExperience             String? @db.Text
  mentoringPhilosophy         String? @db.Text
  previousMentoringExperience String? @db.Text
  capacityOfMentees           String?

  education               Json     @default("[]")
  areasOfExpertise        String[]
  servicesOffered         String[]
  referees                Json     @default("[]")
  preferredContactMethods String[]
  socials                 Json     @default("[]")
  otherLinks              Json     @default("[]")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Organization {
  id          String  @id @default(uuid())
  name        String
  acronym     String?
  cacNumber   String  @unique
  phoneNumber String
  publicEmail String?
  state       String
  lga         String
  address     String?
  description String? @db.Text
  logoUrl     String?

  mission String?  @db.Text
  vision  String?  @db.Text
  sectors String[]

  numberOfStaff      Int?
  numberOfVolunteers Int?
  annualBudget       String?

  socials    Json @default("[]")
  otherLinks Json @default("[]")

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  members OrganizationMember[]

  activities  OrganizationActivity[]
  donors      OrganizationDonor[]
  assessments OrganizationAssessment[]
  odaForms    ODAForm[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([state])
}

model OrganizationMember {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  orgRole     String   @default("member")
  // Membership status — active | suspended | removed
  status      String   @default("active")
  invitedById String?
  joinedAt    DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // A user can only have one membership record per organization
  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([userId])
}

model OrganizationActivity {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  sector   String
  who      String
  where    String
  when     Int
  activity String @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
}

model OrganizationDonor {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  donor    String
  amount   String
  duration String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
}

model OrganizationAssessment {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  assessmentBody String
  month          Int
  year           Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
}

model AdminPermission {
  id          String   @id @default(uuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Stores an array of permission strings e.g. ["event:read", "event:write"]
  permissions String[]
  updatedAt   DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String // e.g., "USER_DELETED", "RESOURCE_UPLOADED"
  entity    String // e.g., "User", "Resource"
  entityId  String
  details   Json?
  adminId   String
  admin     User     @relation(fields: [adminId], references: [id])
  createdAt DateTime @default(now())
}

model ODAForm {
  id             String     @id @default(uuid())
  status         FormStatus @default(IN_PROGRESS)
  buildingBlock  String // e.g., "Governance"
  indicatorScore Int? // The 1-4 score suggested by AI
  evidenceUrl    String? // PDF uploaded by NGO
  aiAnalysis     String?    @db.Text // The "Growth Pathway" report

  organization Organization @relation(fields: [orgId], references: [id])
  orgId        String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model Badge {
  id             String  @id @default(uuid())
  name           String  @unique
  imageUrl       String
  externalSource Boolean @default(false)

  users     User[]
  resources Resource[]

  createdAt DateTime @default(now())
}

model Category {
  id   String @id @default(uuid())
  name String @unique

  parentId  String?
  parent    Category?  @relation("SubCategories", fields: [parentId], references: [id])
  children  Category[] @relation("SubCategories")
  resources Resource[]
}

model Tag {
  id        String     @id @default(uuid())
  name      String     @unique
  resources Resource[]
}

model Resource {
  id          String       @id @default(uuid())
  title       String
  description String       @db.Text
  contentUrl  String?
  rawText     String?      @db.Text
  type        ResourceType
  author      String?
  language    String?
  region      String?
  sector      String?
  fileSize    Int?
  points      Int          @default(0)

  badgeId String?
  badge   Badge?  @relation(fields: [badgeId], references: [id])

  categoryId String
  category   Category      @relation(fields: [categoryId], references: [id])
  tags       Tag[]
  downloads  DownloadLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
  @@index([type])
  @@index([language])
  @@index([sector])
  @@index([region])
  @@index([createdAt])
  @@index([badgeId])
}

model DownloadLog {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  resourceId String
  resource   Resource @relation(fields: [resourceId], references: [id])
  timestamp  DateTime @default(now())

  @@index([userId])
  @@index([resourceId])
}

model Event {
  id                 String   @id @default(uuid())
  title              String
  description        String   @db.Text
  startTime          DateTime
  endTime            DateTime
  coverImageUrl      String? // Azure Blob URL
  jitsiRoomId        String   @unique
  externalMeetingUrl String? // Overrides Jitsi if set (Zoom, Teams, etc.)
  capacity           Int? // null = unlimited
  tags               String[] // Thematic tags for discovery
  isPast             Boolean  @default(false)
  isCancelled        Boolean  @default(false)
  cancellationReason String?
  archiveUrl         String? // Azure Media Services recording URL

  registrations EventRegistration[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([startTime])
  @@index([isPast])
  @@index([isCancelled])
}

model EventRegistration {
  id        String   @id @default(uuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, eventId]) // Prevents double registration
}

model ForumThread {
  id        String   @id @default(uuid())
  title     String
  content   String   @db.Text
  isPrivate Boolean  @default(false)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  posts     Post[]
  createdAt DateTime @default(now())
}

model Post {
  id        String      @id @default(uuid())
  content   String      @db.Text
  threadId  String
  thread    ForumThread @relation(fields: [threadId], references: [id])
  authorId  String
  author    User        @relation(fields: [authorId], references: [id])
  createdAt DateTime    @default(now())
}
