generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      String                   @id @default(uuid())
  email                   String                   @unique
  passwordHash            String
  fullName                String
  role                    Role                     @default(GUEST)
  status                  ApprovalStatus           @default(PENDING)
  isEmailVerified         Boolean                  @default(false)
  otp                     String?
  otpExpiresAt            DateTime?
  resetPasswordToken      String?                  @unique
  resetPasswordExpiresAt  DateTime?
  avatarUrl               String?
  phoneNumber             String?
  pointsCount             Int                      @default(0)
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  achievements            Achievement[]            @relation("UserAchievements")
  adminPermission         AdminPermission?
  actionsPerformed        AuditLog[]
  communitiesCreated      Community[]              @relation("CommunityCreator")
  commentsAuthored        CommunityComment[]       @relation("CommentAuthor")
  communityLikes          CommunityLike[]          @relation("CommunityLikes")
  communityMemberships    CommunityMembership[]    @relation("CommunityMemberships")
  communityMentions       CommunityMention[]       @relation("CommunityMentions")
  communityReports        CommunityReport[]        @relation("CommunityReports")
  communityCommentReports CommunityCommentReport[] @relation("CommentReports")
  topicsAuthored          CommunityTopic[]         @relation("TopicAuthor")
  downloads               DownloadLog[]
  eventsCreated           Event[]                  @relation("EventCreator")
  events                  EventRegistration[]
  expertProfile           ExpertProfile?
  mentorAssignments       MentorRequest[]          @relation("MentorAssignments")
  mentorRequests          MentorRequest[]          @relation("MentorRequests")
  newsPosts               NewsPost[]               @relation("NewsAuthor")
  notifications           Notification[]
  organization            Organization?
  organizationMemberships OrganizationMember[]
  resourceCompletions     ResourceCompletion[]     @relation("ResourceCompletions")
  resourceLinkCompletions ResourceLinkCompletion[] @relation("ResourceLinkCompletions")
  resourceViews           ResourceView[]           @relation("ResourceViews")
  topicViews              TopicView[]              @relation("TopicViews")
  badges                  Badge[]                  @relation("BadgeToUser")

  @@index([role])
  @@index([status])
  @@index([resetPasswordToken])
}

model ExpertProfile {
  id                          String   @id @default(uuid())
  userId                      String   @unique
  title                       String?
  yearsOfExperience           Int?
  about                       String?
  employer                    String?
  otherExperience             String?
  mentoringPhilosophy         String?
  previousMentoringExperience String?
  capacityOfMentees           String?
  education                   Json     @default("[]")
  areasOfExpertise            String[]
  servicesOffered             String[]
  referees                    Json     @default("[]")
  preferredContactMethods     String[]
  socials                     Json     @default("[]")
  otherLinks                  Json     @default("[]")
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt
  areaToApply                 String[]
  companyPitch                String?
  country                     String?
  fees                        String?
  hoursPerWeek                String?
  institutionAttended         String?
  otherAreasOfTopics          String?
  state                       String?
  user                        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Organization {
  id                        String                   @id @default(uuid())
  name                      String
  acronym                   String?
  cacNumber                 String                   @unique
  phoneNumber               String
  publicEmail               String?
  state                     String
  lga                       String
  address                   String?
  description               String?
  logoUrl                   String?
  mission                   String?
  vision                    String?
  sectors                   String[]
  numberOfStaff             Int?
  numberOfVolunteers        Int?
  annualBudget              String?
  socials                   Json                     @default("[]")
  otherLinks                Json                     @default("[]")
  userId                    String                   @unique
  createdAt                 DateTime                 @default(now())
  updatedAt                 DateTime                 @updatedAt
  hasHumanitarianExperience Boolean                  @default(true)
  isInterestedInTraining    Boolean                  @default(true)
  isLocalOrNational         Boolean                  @default(true)
  devPlanPriorityAreas      DevPlanPriorityArea[]
  odaAssessments            ODAAssessment[]
  user                      User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  activities                OrganizationActivity[]
  assessments               OrganizationAssessment[]
  donors                    OrganizationDonor[]
  members                   OrganizationMember[]
  spotlightEntries          SpotlightEntry[]
  spotlightHistory          SpotlightHistory[]

  @@index([state])
}

model OrganizationMember {
  id             String       @id @default(uuid())
  organizationId String
  userId         String
  orgRole        String       @default("member")
  status         String       @default("active")
  invitedById    String?
  joinedAt       DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([userId])
}

model OrganizationActivity {
  id             String       @id @default(uuid())
  organizationId String
  sector         String
  who            String
  where          String
  when           Int
  activity       String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model OrganizationDonor {
  id             String       @id @default(uuid())
  organizationId String
  donor          String
  amount         String
  duration       String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model OrganizationAssessment {
  id             String       @id @default(uuid())
  organizationId String
  assessmentBody String
  month          Int
  year           Int
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model AdminPermission {
  id          String   @id @default(uuid())
  userId      String   @unique
  permissions String[]
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  entity    String
  entityId  String
  details   Json?
  adminId   String
  createdAt DateTime @default(now())
  admin     User     @relation(fields: [adminId], references: [id])
}

model ODAPillar {
  id                   String                @id @default(uuid())
  name                 String                @unique
  order                Int
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  devPlanPriorityAreas DevPlanPriorityArea[]
  buildingBlocks       ODABuildingBlock[]
}

model ODABuildingBlock {
  id                   String                @id @default(uuid())
  name                 String                @unique
  order                Int
  maxScore             Int                   @default(100)
  pillarId             String
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  devPlanPriorityAreas DevPlanPriorityArea[]
  blockResponses       ODABlockResponse[]
  pillar               ODAPillar             @relation(fields: [pillarId], references: [id], onDelete: Cascade)
  questions            ODAQuestion[]

  @@index([pillarId])
}

model ODAQuestion {
  id                   String                @id @default(uuid())
  text                 String
  order                Int
  buildingBlockId      String
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  devPlanPriorityAreas DevPlanPriorityArea[]
  buildingBlock        ODABuildingBlock      @relation(fields: [buildingBlockId], references: [id], onDelete: Cascade)

  @@index([buildingBlockId])
}

model ODAAssessment {
  id             String             @id @default(uuid())
  status         FormStatus         @default(IN_PROGRESS)
  overallScore   Float?
  aiSummary      String?
  startedAt      DateTime           @default(now())
  completedAt    DateTime?
  orgId          String
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  organization   Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  blockResponses ODABlockResponse[]

  @@index([orgId])
  @@index([status])
}

model ODABlockResponse {
  id              String           @id @default(uuid())
  status          ODABlockStatus   @default(IN_PROGRESS)
  blockScore      Float?
  answers         Json             @default("[]")
  assessmentId    String
  buildingBlockId String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  assessment      ODAAssessment    @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  buildingBlock   ODABuildingBlock @relation(fields: [buildingBlockId], references: [id])

  @@unique([assessmentId, buildingBlockId])
  @@index([assessmentId])
}

model Badge {
  id             String        @id @default(uuid())
  name           String        @unique
  imageUrl       String
  externalSource Boolean       @default(false)
  createdAt      DateTime      @default(now())
  achievements   Achievement[] @relation("AchievementBadge")
  resources      Resource[]
  users          User[]        @relation("BadgeToUser")
}

model Category {
  id        String     @id @default(uuid())
  name      String     @unique
  parentId  String?
  imageUrl  String?
  parent    Category?  @relation("SubCategories", fields: [parentId], references: [id])
  children  Category[] @relation("SubCategories")
  resources Resource[]
}

model Tag {
  id        String     @id @default(uuid())
  name      String     @unique
  resources Resource[] @relation("ResourceToTag")
}

model Resource {
  id          String               @id @default(uuid())
  title       String
  description String
  contentUrl  String?
  rawText     String?
  type        ResourceType
  author      String?
  language    String?
  region      String?
  sector      String?
  fileSize    Int?
  points      Int                  @default(0)
  badgeId     String?
  categoryId  String
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  imageUrl    String?
  downloads   DownloadLog[]
  badge       Badge?               @relation(fields: [badgeId], references: [id])
  category    Category             @relation(fields: [categoryId], references: [id])
  completions ResourceCompletion[]
  links       ResourceLink[]
  views       ResourceView[]
  tags        Tag[]                @relation("ResourceToTag")

  @@index([categoryId])
  @@index([type])
  @@index([language])
  @@index([sector])
  @@index([region])
  @@index([createdAt])
  @@index([badgeId])
}

model ResourceLink {
  id          String                   @id @default(uuid())
  title       String
  url         String
  order       Int                      @default(0)
  resourceId  String
  resource    Resource                 @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  completions ResourceLinkCompletion[]

  @@index([resourceId])
}

model ResourceLinkCompletion {
  id             String       @id @default(uuid())
  userId         String
  user           User         @relation("ResourceLinkCompletions", fields: [userId], references: [id], onDelete: Cascade)
  resourceLinkId String
  resourceLink   ResourceLink @relation(fields: [resourceLinkId], references: [id], onDelete: Cascade)
  completedAt    DateTime     @default(now())

  @@unique([userId, resourceLinkId])
  @@index([userId])
  @@index([resourceLinkId])
}

model ResourceView {
  id         String   @id @default(uuid())
  userId     String
  resourceId String
  viewedAt   DateTime @default(now())
  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  user       User     @relation("ResourceViews", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, resourceId])
  @@index([userId])
  @@index([resourceId])
}

model ResourceCompletion {
  id           String   @id @default(uuid())
  userId       String
  resourceId   String
  pointsEarned Int      @default(0)
  completedAt  DateTime @default(now())
  resource     Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  user         User     @relation("ResourceCompletions", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, resourceId])
  @@index([userId])
  @@index([resourceId])
}

model DownloadLog {
  id         String   @id @default(uuid())
  userId     String
  resourceId String
  timestamp  DateTime @default(now())
  resource   Resource @relation(fields: [resourceId], references: [id])
  user       User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([resourceId])
}

model Event {
  id                 String              @id @default(uuid())
  title              String
  description        String
  startTime          DateTime
  endTime            DateTime
  coverImageUrl      String?
  jitsiRoomId        String              @unique
  externalMeetingUrl String?
  capacity           Int?
  tags               String[]
  isPast             Boolean             @default(false)
  isCancelled        Boolean             @default(false)
  cancellationReason String?
  archiveUrl         String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  createdById        String
  isPublic           Boolean             @default(true)
  createdBy          User                @relation("EventCreator", fields: [createdById], references: [id])
  registrations      EventRegistration[]

  @@index([startTime])
  @@index([isPast])
  @@index([isCancelled])
  @@index([createdById])
  @@index([isPublic])
}

model EventRegistration {
  id         String   @id @default(uuid())
  eventId    String
  userId     String?
  createdAt  DateTime @default(now())
  guestEmail String?
  guestName  String?
  event      Event    @relation(fields: [eventId], references: [id])
  user       User?    @relation(fields: [userId], references: [id])

  @@unique([userId, eventId])
  @@unique([guestEmail, eventId])
  @@index([eventId])
  @@index([guestEmail])
}

model MentorRequest {
  id              String              @id @default(uuid())
  ngoUserId       String
  mentorId        String
  status          MentorRequestStatus @default(PENDING)
  hoursPerWeek    String?
  mentorshipAreas String[]
  commMethods     String[]
  orgChallenges   String?
  background      String?
  acceptedTerms   Boolean             @default(false)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  mentor          User                @relation("MentorAssignments", fields: [mentorId], references: [id])
  ngoUser         User                @relation("MentorRequests", fields: [ngoUserId], references: [id])

  @@index([ngoUserId])
  @@index([mentorId])
}

model DevPlanPriorityArea {
  id              String             @id @default(uuid())
  orgId           String
  pillarId        String
  buildingBlockId String
  indicatorId     String
  score           Float?
  strength        String?
  weakness        String?
  opportunity     String?
  threat          String?
  priority        Int
  act             String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  actionPlan      DevPlanActionPlan?
  evaluation      DevPlanEvaluation?
  buildingBlock   ODABuildingBlock   @relation(fields: [buildingBlockId], references: [id])
  indicator       ODAQuestion        @relation(fields: [indicatorId], references: [id])
  organization    Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  pillar          ODAPillar          @relation(fields: [pillarId], references: [id])

  @@index([orgId])
  @@index([pillarId])
  @@index([buildingBlockId])
  @@index([indicatorId])
}

model DevPlanActionPlan {
  id                String              @id @default(uuid())
  priorityAreaId    String              @unique
  objective         String?
  kpi               String?
  actionSteps       String?
  responsiblePerson String?
  timeline          DateTime?
  support           String?
  resourcePlan      String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  priorityArea      DevPlanPriorityArea @relation(fields: [priorityAreaId], references: [id], onDelete: Cascade)
}

model DevPlanEvaluation {
  id                String              @id @default(uuid())
  priorityAreaId    String              @unique
  whatWasDone       String?
  wereObjectivesMet String?
  whatDidWeLearn    String?
  nextSteps         String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  priorityArea      DevPlanPriorityArea @relation(fields: [priorityAreaId], references: [id], onDelete: Cascade)
}

model Community {
  id          String                @id @default(uuid())
  name        String                @unique
  description String?
  imageUrl    String?
  isActive    Boolean               @default(true)
  createdById String
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  createdBy   User                  @relation("CommunityCreator", fields: [createdById], references: [id])
  memberships CommunityMembership[]
  mentions    CommunityMention[]
  topics      CommunityTopic[]

  @@index([isActive])
}

model CommunityMembership {
  id          String    @id @default(uuid())
  userId      String
  communityId String
  joinedAt    DateTime  @default(now())
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  user        User      @relation("CommunityMemberships", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, communityId])
  @@index([userId])
  @@index([communityId])
}

model CommunityTopic {
  id          String             @id @default(uuid())
  title       String
  body        String
  isBlocked   Boolean            @default(false)
  likeCount   Int                @default(0)
  communityId String
  authorId    String
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  viewCount   Int                @default(0)
  comments    CommunityComment[]
  likes       CommunityLike[]
  mentions    CommunityMention[]
  reports     CommunityReport[]
  author      User               @relation("TopicAuthor", fields: [authorId], references: [id])
  community   Community          @relation(fields: [communityId], references: [id], onDelete: Cascade)
  views       TopicView[]

  @@index([communityId])
  @@index([authorId])
  @@index([isBlocked])
  @@index([viewCount])
}

model TopicView {
  id        String         @id @default(uuid())
  userId    String
  topicId   String
  createdAt DateTime       @default(now())
  topic     CommunityTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  user      User           @relation("TopicViews", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, topicId])
  @@index([userId])
  @@index([topicId])
}

model CommunityComment {
  id        String             @id @default(uuid())
  body      String
  likeCount Int                @default(0)
  topicId   String
  authorId  String
  parentId  String?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  author    User               @relation("CommentAuthor", fields: [authorId], references: [id])
  parent    CommunityComment?  @relation("Replies", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  replies   CommunityComment[] @relation("Replies")
  topic     CommunityTopic     @relation(fields: [topicId], references: [id], onDelete: Cascade)
  likes     CommunityLike[]
  mentions  CommunityMention[]

  isQuote   Boolean                  @default(false)
  quoteId   String?
  quote     CommunityComment?        @relation("CommentQuotes", fields: [quoteId], references: [id], onDelete: SetNull)
  quotedBy  CommunityComment[]       @relation("CommentQuotes")
  isBlocked Boolean                  @default(false)
  reports   CommunityCommentReport[]

  @@index([topicId])
  @@index([authorId])
  @@index([parentId])
  @@index([isBlocked])
  @@index([quoteId])
}

model CommunityLike {
  id        String            @id @default(uuid())
  userId    String
  topicId   String?
  commentId String?
  createdAt DateTime          @default(now())
  comment   CommunityComment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
  topic     CommunityTopic?   @relation(fields: [topicId], references: [id], onDelete: Cascade)
  user      User              @relation("CommunityLikes", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, topicId])
  @@unique([userId, commentId])
  @@index([userId])
}

model CommunityReport {
  id           String         @id @default(uuid())
  reason       String?
  reportedById String
  topicId      String
  createdAt    DateTime       @default(now())
  reportedBy   User           @relation("CommunityReports", fields: [reportedById], references: [id], onDelete: Cascade)
  topic        CommunityTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@unique([topicId, reportedById])
  @@index([topicId])
  @@index([reportedById])
}

model CommunityCommentReport {
  id           String           @id @default(uuid())
  reason       String?          @db.Text
  reportedById String
  reportedBy   User             @relation("CommentReports", fields: [reportedById], references: [id], onDelete: Cascade)
  commentId    String
  comment      CommunityComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  createdAt    DateTime         @default(now())

  @@unique([commentId, reportedById])
  @@index([commentId])
  @@index([reportedById])
}

model CommunityMention {
  id              String            @id @default(uuid())
  mentionedUserId String
  topicId         String?
  commentId       String?
  createdAt       DateTime          @default(now())
  communityId     String?
  comment         CommunityComment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
  community       Community?        @relation(fields: [communityId], references: [id])
  mentionedUser   User              @relation("CommunityMentions", fields: [mentionedUserId], references: [id], onDelete: Cascade)
  topic           CommunityTopic?   @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@index([mentionedUserId])
  @@index([communityId])
}

model NewsPost {
  id           String         @id @default(uuid())
  title        String
  slug         String         @unique
  type         String
  body         String
  excerpt      String?
  thumbnailUrl String?
  attachments  Json           @default("[]")
  status       NewsPostStatus @default(DRAFT)
  publishedAt  DateTime?
  tags         String[]
  viewCount    Int            @default(0)
  authorId     String
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  author       User           @relation("NewsAuthor", fields: [authorId], references: [id])

  @@index([status])
  @@index([type])
  @@index([authorId])
  @@index([publishedAt])
  @@index([viewCount])
}

model SpotlightSettings {
  id                String        @id @default("singleton")
  defaultPeriodDays Int           @default(2)
  mode              SpotlightMode @default(AUTO)
  updatedAt         DateTime      @updatedAt
}

model SpotlightEntry {
  id        String       @id @default(uuid())
  orgId     String
  startAt   DateTime
  endAt     DateTime
  isActive  Boolean      @default(false)
  wasAuto   Boolean      @default(false)
  order     Int?
  createdAt DateTime     @default(now())
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([isActive])
  @@index([startAt])
  @@index([endAt])
}

model SpotlightHistory {
  id        String       @id @default(uuid())
  orgId     String
  startAt   DateTime
  endAt     DateTime
  wasAuto   Boolean
  createdAt DateTime     @default(now())
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([startAt])
}

model Achievement {
  id          String   @id @default(uuid())
  userId      String
  title       String
  description String
  points      Int      @default(0)
  badgeId     String?
  earnedAt    DateTime @default(now())
  badge       Badge?   @relation("AchievementBadge", fields: [badgeId], references: [id])
  user        User     @relation("UserAchievements", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([earnedAt])
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  link      String?
  meta      Json?
  isRead    Boolean          @default(false)
  readAt    DateTime?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([isRead])
}

// ─────────────────────────────────────────────────────────────────────────────
// CONTACT US
// ─────────────────────────────────────────────────────────────────────────────

enum ContactMessageStatus {
  UNREAD
  READ
  REPLIED
  ARCHIVED
}

model ContactMessage {
  id        String               @id @default(uuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String
  status    ContactMessageStatus @default(UNREAD)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  @@index([status])
  @@index([createdAt])
}

enum Role {
  SUPER_ADMIN
  CONTENT_ADMIN
  EVENT_ADMIN
  RESOURCE_ADMIN
  NGO_MEMBER
  EXPERT
  GUEST
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum FormStatus {
  IN_PROGRESS
  SUBMITTED
  COMPLETED
}

enum ResourceType {
  DOCUMENT
  VIDEO
  ARTICLE
  MULTILINK
}

enum MentorRequestStatus {
  PENDING
  APPROVED
  DECLINED
  COMPLETED
}

enum ODABlockStatus {
  IN_PROGRESS
  SUBMITTED
}

enum NewsPostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum SpotlightMode {
  AUTO
  MANUAL
}

enum NotificationType {
