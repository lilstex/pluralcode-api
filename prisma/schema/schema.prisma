generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  CONTENT_ADMIN
  EVENT_ADMIN
  RESOURCE_ADMIN
  NGO_MEMBER
  EXPERT
  GUEST
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum FormStatus {
  IN_PROGRESS
  SUBMITTED
  COMPLETED
}

enum ResourceType {
  DOCUMENT
  VIDEO
  AUDIO
  ARTICLE
}

model User {
  id                     String         @id @default(uuid())
  email                  String         @unique
  passwordHash           String
  fullName               String
  role                   Role           @default(GUEST)
  status                 ApprovalStatus @default(PENDING)
  isEmailVerified        Boolean        @default(false)
  otp                    String?
  otpExpiresAt           DateTime?
  resetPasswordToken     String?        @unique
  resetPasswordExpiresAt DateTime?
  avatarUrl              String?

  // --- EXPERT FIELDS ---
  title             String?
  phoneNumber       String?
  yearsOfExperience Int?
  areasOfExpertise  String[]

  // --- NGO RELATION ---
  organization Organization?

  // --- GENERAL RELATIONS ---
  forumThreads     ForumThread[]
  posts            Post[]
  badges           Badge[]
  adminPermission  AdminPermission?
  events           EventRegistration[]
  downloads        DownloadLog[]
  actionsPerformed AuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
  @@index([status])
  @@index([resetPasswordToken])
}

model Organization {
  id          String  @id @default(uuid())
  name        String
  cacNumber   String  @unique
  phoneNumber String
  state       String
  lga         String
  address     String?

  // Backlink to User
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  odaForms    ODAForm[]
  sector      String?
  website     String?
  description String?   @db.Text
  logoUrl     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AdminPermission {
  id          String   @id @default(uuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Stores an array of permission strings e.g. ["event:read", "event:write"]
  permissions String[]
  updatedAt   DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String // e.g., "USER_DELETED", "RESOURCE_UPLOADED"
  entity    String // e.g., "User", "Resource"
  entityId  String
  details   Json?
  adminId   String
  admin     User     @relation(fields: [adminId], references: [id])
  createdAt DateTime @default(now())
}

model ODAForm {
  id             String     @id @default(uuid())
  status         FormStatus @default(IN_PROGRESS)
  buildingBlock  String // e.g., "Governance"
  indicatorScore Int? // The 1-4 score suggested by AI
  evidenceUrl    String? // PDF uploaded by NGO
  aiAnalysis     String?    @db.Text // The "Growth Pathway" report

  organization Organization @relation(fields: [orgId], references: [id])
  orgId        String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model Resource {
  id          String       @id @default(uuid())
  title       String
  description String       @db.Text
  contentUrl  String? // Azure Blob URL or external video URL
  rawText     String?      @db.Text // OCR-extracted text for full-text search
  type        ResourceType
  author      String?
  language    String? // ISO 639-1 e.g. "en", "fr"
  region      String? // Geographic focus e.g. "Lagos", "North-East"
  sector      String? // Thematic sector e.g. "Health", "Education"

  // Relations
  categoryId String
  category   Category      @relation(fields: [categoryId], references: [id])
  tags       Tag[]
  downloads  DownloadLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
  @@index([type])
  @@index([language])
  @@index([sector])
  @@index([region])
  @@index([createdAt])
}

model Category {
  id   String @id @default(uuid())
  name String @unique

  // Self-referencing relationship for sub-categories
  parentId String?
  parent   Category?  @relation("SubCategories", fields: [parentId], references: [id])
  children Category[] @relation("SubCategories")

  resources Resource[]
}

model Tag {
  id        String     @id @default(uuid())
  name      String     @unique
  resources Resource[]
}

model Event {
  id                 String   @id @default(uuid())
  title              String
  description        String   @db.Text
  startTime          DateTime
  endTime            DateTime
  coverImageUrl      String? // Azure Blob URL
  jitsiRoomId        String   @unique
  externalMeetingUrl String? // Overrides Jitsi if set (Zoom, Teams, etc.)
  capacity           Int? // null = unlimited
  tags               String[] // Thematic tags for discovery
  isPast             Boolean  @default(false)
  isCancelled        Boolean  @default(false)
  cancellationReason String?
  archiveUrl         String? // Azure Media Services recording URL

  registrations EventRegistration[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([startTime])
  @@index([isPast])
  @@index([isCancelled])
}

model EventRegistration {
  id        String   @id @default(uuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, eventId]) // Prevents double registration
}

model ForumThread {
  id        String   @id @default(uuid())
  title     String
  content   String   @db.Text
  isPrivate Boolean  @default(false)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  posts     Post[]
  createdAt DateTime @default(now())
}

model Post {
  id        String      @id @default(uuid())
  content   String      @db.Text
  threadId  String
  thread    ForumThread @relation(fields: [threadId], references: [id])
  authorId  String
  author    User        @relation(fields: [authorId], references: [id])
  createdAt DateTime    @default(now())
}

model Badge {
  id             String  @id @default(uuid())
  name           String  @unique
  imageUrl       String
  externalSource Boolean @default(false)
  users          User[] // Implicit many-to-many with User
}

model DownloadLog {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  resourceId String
  resource   Resource @relation(fields: [resourceId], references: [id])
  timestamp  DateTime @default(now())

  @@index([userId])
  @@index([resourceId])
}
