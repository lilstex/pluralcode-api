<%
  var title = 'Reset Your PLRCAP Hub Password';
  var body = `
    <h1 style="color:#1a2b3c; font-size:22px; font-weight:700; margin-bottom:16px; line-height:1.3;">
      Password Reset Request
    </h1>

    <p style="color:#4a5568; font-size:15px; line-height:1.7; margin-bottom:16px;">
      Hi <strong>${fullName}</strong>,
    </p>

    <p style="color:#4a5568; font-size:15px; line-height:1.7; margin-bottom:16px;">
      We received a request to reset the password for your PLRCAP Hub account associated with
      <strong>${email}</strong>. Use the link below to choose a new password.
    </p>

    <!-- Reset link box — visible, copyable, works in every email client -->
    <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin:28px 0;">
      <tr>
        <td style="background:#f0f7ff;
                   border:2px solid #2e86c1;
                   border-radius:8px;
                   padding:20px 24px;">
          <p style="margin:0 0 8px 0;
                    font-size:12px;
                    font-weight:600;
                    color:#2e86c1;
                    text-transform:uppercase;
                    letter-spacing:1px;">
            Your password reset link
          </p>
          <a href="${resetUrl}"
             target="_blank"
             style="font-size:14px;
                    color:#1a5276;
                    word-break:break-all;
                    text-decoration:underline;
                    font-family:'Courier New', Courier, monospace;
                    line-height:1.6;">
            ${resetUrl}
          </a>
        </td>
      </tr>
    </table>

    <p style="color:#4a5568; font-size:14px; line-height:1.7; margin-bottom:0;">
      Copy the link above and paste it into your browser's address bar to reset your password.
    </p>

    <hr style="border:none; border-top:1px solid #e2e8f0; margin:28px 0;" />

    <!-- Info alert -->
    <div style="background:#eff6ff;
                border-left:4px solid #3b82f6;
                border-radius:8px;
                padding:16px 20px;
                margin:0 0 16px 0;
                font-size:14px;
                line-height:1.6;
                color:#1e40af;">
      <p style="margin:0;">
        <strong>Note:</strong> This link is secure and will expire in <strong>60 minutes</strong>.
        For your security, it can only be used once.
      </p>
    </div>

    <!-- Danger alert -->
    <div style="background:#fef2f2;
                border-left:4px solid #ef4444;
                border-radius:8px;
                padding:16px 20px;
                margin:0;
                font-size:14px;
                line-height:1.6;
                color:#991b1b;">
      <strong>Did not request this?</strong> Your account may be at risk.
      Please <a href="mailto:support@plrcap.org"
                style="color:#991b1b; font-weight:600; text-decoration:underline;">
        contact support
      </a> immediately and do <strong>not</strong> share this link with anyone.
    </div>
  `;
%>
<%- include('_layout', { title, body }) %>