<%
  var title = 'Reset Your PLRCAP Hub Password';
  var body = `
    <h1>Password Reset Request</h1>
    <p>Hi <strong>${fullName}</strong>,</p>
    <p>
      We received a request to reset the password for your PLRCAP Hub account.
      Use the OTP below to complete your password reset.
    </p>

    <div class="otp-box">
      <div class="otp-label">Password Reset Code</div>
      <div class="otp-code">${otp}</div>
      <div class="otp-expiry">&#x23F1; This code expires in <strong>15 minutes</strong></div>
    </div>

    <div class="alert alert-danger">
      <strong>Did not request this?</strong> Your account may be at risk.
      Please <a href="mailto:support@plrcap.org" style="color:#991b1b; font-weight:600;">contact support</a> immediately
      and do <strong>not</strong> share this code with anyone.
    </div>

    <hr class="divider" />

    <p style="font-size:13px; color:#718096;">
      Reset requested for: <strong>${email}</strong><br />
      If you did not make this request, you can safely ignore this email —
      your password will not be changed.
    </p>
  `;
%>
<%- include('_layout', { title, body }) %>