<%
  var title = 'Reset Your PLRCAP Hub Password';
  var body = `
    <h1>Password Reset Request</h1>
    <p>Hi <strong>${fullName}</strong>,</p>
    <p>
      We received a request to reset the password for your PLRCAP Hub account associated with <strong>${email}</strong>.
      Click the button below to choose a new password.
    </p>

    <div class="btn-wrapper">
      <a href="${resetUrl}" class="btn">Reset My Password</a>
    </div>

    <div class="alert alert-info">
      <p style="margin-bottom: 0;">
        <strong>Note:</strong> This link is secure and will expire in <strong>60 minutes</strong>. 
        For your security, it can only be used once.
      </p>
    </div>

    <div class="alert alert-danger">
      <strong>Did not request this?</strong> Your account may be at risk.
      Please <a href="mailto:support@plrcap.org" style="color:#991b1b; font-weight:600;">contact support</a> immediately
      and do <strong>not</strong> share this link with anyone.
    </div>

    <hr class="divider" />

    <p style="font-size:12px; color:#718096; line-height: 1.4;">
      If the button above doesn't work, copy and paste this link into your browser:<br />
      <a href="${resetUrl}" style="color: #2e86c1; word-break: break-all;">${resetUrl}</a>
    </p>
  `;
%>
<%- include('_layout', { title, body }) %>