<%
  var title = 'We received your message — PLRCAP NGO Hub';
  var body = `
    <h1 style="color:#1a2b3c; font-size:22px; font-weight:700; margin-bottom:16px; line-height:1.3;">
      Thank you for reaching out!
    </h1>

    <p style="color:#4a5568; font-size:15px; line-height:1.7; margin-bottom:16px;">
      Hi <strong>${name}</strong>,
    </p>

    <p style="color:#4a5568; font-size:15px; line-height:1.7; margin-bottom:16px;">
      We have received your message and our team will review it shortly.
      You can expect a response within <strong>3 business days</strong>.
    </p>

    <div style="background:#ecfdf5;
                border-left:4px solid #10b981;
                border-radius:8px;
                padding:16px 20px;
                margin:24px 0;
                font-size:14px;
                line-height:1.6;
                color:#065f46;">
      <p style="margin:0;">
        Your message has been received and logged. A member of our team will be in touch soon.
      </p>
    </div>

    <p style="color:#4a5568; font-size:15px; line-height:1.7; margin-bottom:16px;">
      In the meantime, you can explore the PLRCAP NGO Support Hub for resources,
      training materials, and community discussions designed to support Nigerian NGOs.
    </p>

    <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin:32px 0;">
      <tr>
        <td align="center">
          <a href="${process.env.FRONTEND_URL ?? 'https://dev-plrcap.vercel.app'}"
             target="_blank"
             style="display:inline-block;
                    background:linear-gradient(135deg,#1a5276 0%,#2e86c1 100%);
                    color:#ffffff;
                    font-size:15px;
                    font-weight:600;
                    padding:14px 36px;
                    border-radius:8px;
                    letter-spacing:0.3px;
                    text-decoration:none;
                    font-family:Arial,sans-serif;">
            Visit the Hub
          </a>
        </td>
      </tr>
    </table>

    <hr style="border:none; border-top:1px solid #e2e8f0; margin:28px 0;" />

    <p style="font-size:12px; color:#718096; line-height:1.6; margin:0;">
      If you did not submit this form or believe this is an error, please
      <a href="mailto:support@plrcap.org" style="color:#2e86c1;">contact support</a>.
    </p>
  `;
%>
<%- include('_layout', { title, body }) %>