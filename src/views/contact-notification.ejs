<%
  var title = 'New Contact Form Submission — PLRCAP Hub';
  var body = `
    <h1 style="color:#1a2b3c; font-size:20px; font-weight:700; margin-bottom:16px; line-height:1.3;">
      New Contact Form Submission
    </h1>

    <p style="color:#4a5568; font-size:15px; line-height:1.7; margin-bottom:20px;">
      A visitor has submitted a message via the PLRCAP NGO Hub contact form.
      The details are below.
    </p>

    <table width="100%" cellpadding="0" cellspacing="0" border="0"
           style="background:#f8fafc; border-radius:8px; padding:20px 24px; margin:24px 0;">
      <tr>
        <td style="padding:7px 0; font-size:14px; color:#1a2b3c; font-weight:600; width:140px; vertical-align:top;">
          Name
        </td>
        <td style="padding:7px 0; font-size:14px; color:#4a5568; vertical-align:top;">
          ${name}
        </td>
      </tr>
      <tr>
        <td style="padding:7px 0; font-size:14px; color:#1a2b3c; font-weight:600; vertical-align:top;">
          Email
        </td>
        <td style="padding:7px 0; font-size:14px; color:#4a5568; vertical-align:top;">
          <a href="mailto:${email}" style="color:#2e86c1; text-decoration:none;">${email}</a>
        </td>
      </tr>
      ${phone ? `
      <tr>
        <td style="padding:7px 0; font-size:14px; color:#1a2b3c; font-weight:600; vertical-align:top;">
          Phone
        </td>
        <td style="padding:7px 0; font-size:14px; color:#4a5568; vertical-align:top;">
          ${phone}
        </td>
      </tr>` : ''}
      <tr>
        <td style="padding:7px 0; font-size:14px; color:#1a2b3c; font-weight:600; vertical-align:top;">
          Subject
        </td>
        <td style="padding:7px 0; font-size:14px; color:#4a5568; vertical-align:top;">
          ${subject}
        </td>
      </tr>
      <tr>
        <td style="padding:7px 0; font-size:14px; color:#1a2b3c; font-weight:600; vertical-align:top;">
          Submitted
        </td>
        <td style="padding:7px 0; font-size:14px; color:#4a5568; vertical-align:top;">
          ${new Date(createdAt).toLocaleString('en-GB', { dateStyle: 'full', timeStyle: 'short' })}
        </td>
      </tr>
    </table>

    <p style="color:#1a2b3c; font-size:14px; font-weight:600; margin-bottom:8px;">Message</p>
    <div style="background:#ffffff;
                border:1px solid #e2e8f0;
                border-left:4px solid #2e86c1;
                border-radius:8px;
                padding:20px 24px;
                font-size:14px;
                color:#4a5568;
                line-height:1.8;
                white-space:pre-wrap;">
      ${message}
    </div>

    <hr style="border:none; border-top:1px solid #e2e8f0; margin:28px 0;" />

    <p style="font-size:12px; color:#718096; line-height:1.6; margin:0;">
      Reply directly to <a href="mailto:${email}" style="color:#2e86c1;">${email}</a>
      or log into the admin dashboard to update the message status.
    </p>
  `;
%>
<%- include('_layout', { title, body }) %>