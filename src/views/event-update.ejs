<%
  var title = 'Event Update: ' + eventTitle;
  var formattedStart = new Date(startTime).toLocaleString('en-NG', { dateStyle: 'full', timeStyle: 'short', timeZone: 'Africa/Lagos' });
  var formattedEnd   = new Date(endTime).toLocaleString('en-NG', { timeStyle: 'short', timeZone: 'Africa/Lagos' });

  var body = `
    <h1>Event Schedule Updated</h1>
    <p>Hi <strong>${fullName}</strong>,</p>
    <p>
      The details for an event you are registered for have been updated.
      Please review the new schedule below.
    </p>

    <table class="info-table">
      <tr>
        <td class="label">Event</td>
        <td><strong>${eventTitle}</strong></td>
      </tr>
      <tr>
        <td class="label">New Date &amp; Time</td>
        <td>${formattedStart} – ${formattedEnd} (WAT)</td>
      </tr>
      <tr>
        <td class="label">Meeting Link</td>
        <td><a href="${meetingUrl}" style="color:#2e86c1;">${meetingUrl}</a></td>
      </tr>
    </table>

    <div class="alert alert-warning">
      &#128197; Please update your calendar with the new time.
      A new calendar invite is attached to this email.
    </div>

    <div class="btn-wrapper">
      <a href="${meetingUrl}" class="btn">View Event &rarr;</a>
    </div>
  `;
%>
<%- include('_layout', { title, body }) %>