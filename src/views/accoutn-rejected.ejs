<%
  var title = 'Your PLRCAP Account Application Update';
  var body = `
    <h1>Application Status Update</h1>
    <p>Hi <strong>${fullName}</strong>,</p>
    <p>
      Thank you for your interest in joining the <strong>PLRCAP/NORCAP NGO Support Hub</strong>.
      After reviewing your registration, we are unable to approve your account at this time.
    </p>

    <div class="alert alert-danger">
      &#x2715;&nbsp; Your account application has been <strong>declined</strong>.
    </div>

    ${reason ? `
    <table class="info-table">
      <tr>
        <td class="label">Reason</td>
        <td>${reason}</td>
      </tr>
    </table>
    ` : ''}

    <p>
      If you believe this decision was made in error, or if you would like to provide
      additional information to support your application, please reach out to our team directly.
    </p>

    <div class="btn-wrapper">
      <a href="mailto:support@plrcap.org?subject=Account Application Review - ${encodeURIComponent(email)}" class="btn">
        Contact Support
      </a>
    </div>

    <hr class="divider" />

    <p style="font-size:13px; color:#718096;">
      Application email: <strong>${email}</strong><br />
      You may reapply once the issue has been resolved.
    </p>
  `;
%>
<%- include('_layout', { title, body }) %>